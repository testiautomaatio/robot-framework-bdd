{
    "name": "robot-framework-bdd",
    "image": "mcr.microsoft.com/devcontainers/python:3",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {}
    },
    "runArgs": [
        "--init",
        "--shm-size=1g"
    ],
    "postCreateCommand": "bash .devcontainer/postCreate.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "d-biehl.robotcode"
            ]
        }
    }
}
